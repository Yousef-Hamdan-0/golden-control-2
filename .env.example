# Copy this file to ".env.local" and fill in real values when we wire the backend.
# Nothing here is needed yet to run Screen 1.

# Backend API base URL (used later by the Axios client)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Socket.IO server URL (used later by the realtime layer)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
