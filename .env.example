# Copy this file to ".env.local" and set the real backend values.

# Backend API base URL. Endpoint paths live in src/config/api-endpoints.ts
NEXT_PUBLIC_API_URL=http://localhost:4000

# Temporary fallback until Firebase Messaging saves a real FCM device token.

NEXT_PUBLIC_DEFAULT_DEVICE_TOKEN=fcm-token-xyz-123

# Socket.IO server URL (used later by the realtime layer)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
